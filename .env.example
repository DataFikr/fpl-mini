# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/fpl_league_hub"

# Redis Configuration (optional - will use memory cache if not provided)
REDIS_URL="redis://localhost:6379"

# FPL API Configuration
FPL_API_BASE_URL="https://fantasy.premierleague.com/api"

# Next.js Configuration
NODE_ENV="production"

# Optional: Database connection pool settings
DATABASE_CONNECTION_LIMIT=5
DATABASE_TIMEOUT=20000

# Email Configuration (Resend)
# 1. Create an API key at https://resend.com/api-keys
# 2. FROM_EMAIL MUST use a domain you have VERIFIED in Resend (Domains tab).
#    Sending from an unverified domain is the #1 cause of subscribe emails
#    silently failing / landing the app in "demo mode".
RESEND_API_KEY="your_resend_api_key_here"
FROM_EMAIL="info@fplranker.com"

# Public base URL used in email links and by cron jobs to call internal APIs.
# In production set this to your deployed origin (e.g. https://fplranker.com).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Cron authentication. Set this in Vercel project env vars; Vercel Cron then
# automatically sends `Authorization: Bearer ${CRON_SECRET}` with each run.
# Required for /api/cron/thursday-reminder and /api/cron/weekly-summary.
CRON_SECRET="generate_a_long_random_string"

# Google Analytics 4 (GA4) Configuration
# Get your Measurement ID from Google Analytics (format: G-XXXXXXXXXX)
# https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"